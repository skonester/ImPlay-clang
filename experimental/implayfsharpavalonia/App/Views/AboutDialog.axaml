<Window
    x:Class="ImPlay.App.Views.AboutDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="About ImPlay"
    Width="380"
    CanResize="False"
    WindowStartupLocation="CenterOwner"
    SizeToContent="Height"
    Background="#1A1A1A">
  <StackPanel Margin="24,20,24,20" Spacing="0">

    <!-- Logo + app name -->
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" Margin="0,0,0,6">
      <Image Width="32" Height="32" Source="avares://ImPlay/Assets/ImPlay/icon.png" />
      <TextBlock Text="ImPlay" FontSize="22" FontWeight="Bold"
                 Foreground="#F7F5F3" VerticalAlignment="Center" />
    </StackPanel>

    <TextBlock Name="VersionText"
               HorizontalAlignment="Center"
               FontSize="12" Foreground="#6A6560" Margin="0,0,0,18" />

    <!-- Divider -->
    <Border Height="1" Background="#2A2A2A" Margin="0,0,0,16" />

    <!-- Info rows -->
    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" Margin="0,0,0,16">
      <TextBlock Grid.Row="0" Grid.Column="0" Text="Platform"
                 FontSize="12" Foreground="#6A6560" Margin="0,0,0,8" />
      <TextBlock Grid.Row="0" Grid.Column="1" Name="OsText"
                 FontSize="12" Foreground="#C8C3C2" Margin="0,0,0,8" />

      <TextBlock Grid.Row="1" Grid.Column="0" Text="Architecture"
                 FontSize="12" Foreground="#6A6560" Margin="0,0,0,8" />
      <TextBlock Grid.Row="1" Grid.Column="1" Name="ArchText"
                 FontSize="12" Foreground="#C8C3C2" Margin="0,0,0,8" />

      <TextBlock Grid.Row="2" Grid.Column="0" Text=".NET runtime"
                 FontSize="12" Foreground="#6A6560" />
      <TextBlock Grid.Row="2" Grid.Column="1" Name="RuntimeText"
                 FontSize="12" Foreground="#C8C3C2" />
    </Grid>

    <!-- Divider -->
    <Border Height="1" Background="#2A2A2A" Margin="0,0,0,16" />

    <!-- Update status -->
    <StackPanel Spacing="10">
      <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
        <TextBlock Name="UpdateStatusText"
                   FontSize="12" Foreground="#6A6560"
                   VerticalAlignment="Center" />
      </StackPanel>

      <Button Name="CheckUpdatesButton"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"
              Click="CheckUpdates_Click"
              Background="#2A2A2A" Foreground="#C8C3C2"
              BorderBrush="#3A3A3A" BorderThickness="1"
              Padding="0,8" CornerRadius="4"
              Content="Check for Updates" />

      <Button Name="OpenReleasesButton"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"
              Click="OpenReleases_Click"
              IsVisible="False"
              Background="#1A2B3D" Foreground="#FFFFFF"
              BorderBrush="#DEDAD5" BorderThickness="1"
              Padding="0,8" CornerRadius="4"
              Content="View Latest Release ↗" />
    </StackPanel>

    <!-- Divider -->
    <Border Height="1" Background="#2A2A2A" Margin="0,16,0,16" />

    <!-- Footer links -->
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16">
      <Button Classes="link" Content="GitHub" Click="GitHub_Click" />
      <TextBlock Text="·" Foreground="#3A3A3A" VerticalAlignment="Center" />
      <Button Classes="link" Content="Releases" Click="Releases_Click" />
      <TextBlock Text="·" Foreground="#3A3A3A" VerticalAlignment="Center" />
      <Button Classes="link" Content="Report an Issue" Click="Issues_Click" />
    </StackPanel>

    <!-- License note -->
    <TextBlock Text="Source Available"
               HorizontalAlignment="Center"
               FontSize="11" Foreground="#3A3835" Margin="0,10,0,4" />

  </StackPanel>
</Window>
