<Window
    x:Class="ImPlay.App.Views.BookmarksDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Bookmarks"
    Width="420"
    MinHeight="120"
    MaxHeight="520"
    CanResize="False"
    WindowStartupLocation="CenterOwner"
    SizeToContent="Height"
    Background="#1A1A1A">
  <StackPanel Margin="16,14,16,16" Spacing="10">

    <!-- Header row: file name + Add button -->
    <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
      <TextBlock Grid.Column="0" Name="FileNameText"
                 FontSize="12" Foreground="#6A6560"
                 TextTrimming="CharacterEllipsis"
                 VerticalAlignment="Center"
                 Margin="0,0,10,0" />
      <Button Grid.Column="1"
              Name="AddButton"
              Content="+ Add here"
              Click="AddButton_Click"
              Background="#222E3A" Foreground="#FFFFFF"
              BorderBrush="#3A5A40" BorderThickness="1"
              Padding="10,6" CornerRadius="4"
              FontSize="12"
              VerticalAlignment="Center"
              VerticalContentAlignment="Center" />
    </Grid>

    <Border Height="1" Background="#2A2A2A" />

    <!-- Empty state -->
    <TextBlock Name="EmptyText"
               Text="No bookmarks yet. Press B while playing to add one."
               FontSize="12" Foreground="#4A4948"
               HorizontalAlignment="Center"
               TextWrapping="Wrap"
               Margin="0,8" />

    <!-- Bookmark list -->
    <ItemsControl Name="BookmarksList">
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,1">

            <!-- Timestamp pill -->
            <Border Grid.Column="0"
                    Background="#2A2A2A" CornerRadius="4"
                    Padding="8,4" Margin="0,0,10,0"
                    VerticalAlignment="Center">
              <TextBlock Name="TimeText"
                         FontSize="12" FontWeight="SemiBold"
                         Foreground="#FFFFFF"
                         FontFamily="Cascadia Code,Consolas,monospace" />
            </Border>

            <!-- Label -->
            <TextBlock Grid.Column="1"
                       Name="LabelText"
                       FontSize="12" Foreground="#C8C3C2"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />

            <!-- Jump button -->
            <Button Grid.Column="2"
                    Name="JumpButton"
                    Content="▶ Jump"
                    Click="JumpButton_Click"
                    Background="Transparent" Foreground="#6A6560"
                    BorderThickness="0"
                    Padding="8,4"
                    FontSize="11" />

            <!-- Delete button -->
            <Button Grid.Column="3"
                    Name="DeleteButton"
                    Click="DeleteButton_Click"
                    Background="Transparent" Foreground="#6A3535"
                    BorderThickness="0"
                    Padding="6,4"
                    FontSize="11"
                    Content="✕" />
          </Grid>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

  </StackPanel>
</Window>
