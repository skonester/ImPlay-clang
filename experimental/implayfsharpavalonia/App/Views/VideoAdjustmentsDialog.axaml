<Window
    x:Class="ImPlay.App.Views.VideoAdjustmentsDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Video Adjustments"
    Width="460"
    Height="490"
    MinWidth="400"
    MinHeight="440"
    CanResize="False"
    WindowStartupLocation="CenterOwner"
    Background="#1E1E1E">

  <Grid RowDefinitions="*,Auto" Margin="20,14,20,16">

    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="0">

        <!-- ── Color correction ─────────────────────────────────────────── -->
        <TextBlock Text="COLOR CORRECTION"
                   FontSize="10" FontWeight="SemiBold"
                   Foreground="#807C79"
                   Margin="0,0,0,10" />

        <!-- Brightness -->
        <Grid ColumnDefinitions="86,*,56" Margin="0,0,0,10">
          <TextBlock Grid.Column="0" Text="Brightness"
                     VerticalAlignment="Center"
                     Foreground="#DEDAD5" FontSize="13" />
          <Slider Grid.Column="1"
                  Name="BrightnessSlider"
                  Minimum="-100" Maximum="100"
                  TickFrequency="1" IsSnapToTickEnabled="True"
                  ValueChanged="BrightnessSlider_Changed"
                  VerticalAlignment="Center" />
          <TextBlock Grid.Column="2"
                     Name="BrightnessVal"
                     Text="+0"
                     Foreground="#F7F5F3" FontSize="12" FontWeight="SemiBold"
                     VerticalAlignment="Center" HorizontalAlignment="Right" />
        </Grid>

        <!-- Contrast -->
        <Grid ColumnDefinitions="86,*,56" Margin="0,0,0,10">
          <TextBlock Grid.Column="0" Text="Contrast"
                     VerticalAlignment="Center"
                     Foreground="#DEDAD5" FontSize="13" />
          <Slider Grid.Column="1"
                  Name="ContrastSlider"
                  Minimum="-100" Maximum="100"
                  TickFrequency="1" IsSnapToTickEnabled="True"
                  ValueChanged="ContrastSlider_Changed"
                  VerticalAlignment="Center" />
          <TextBlock Grid.Column="2"
                     Name="ContrastVal"
                     Text="+0"
                     Foreground="#F7F5F3" FontSize="12" FontWeight="SemiBold"
                     VerticalAlignment="Center" HorizontalAlignment="Right" />
        </Grid>

        <!-- Saturation -->
        <Grid ColumnDefinitions="86,*,56" Margin="0,0,0,20">
          <TextBlock Grid.Column="0" Text="Saturation"
                     VerticalAlignment="Center"
                     Foreground="#DEDAD5" FontSize="13" />
          <Slider Grid.Column="1"
                  Name="SaturationSlider"
                  Minimum="-100" Maximum="100"
                  TickFrequency="1" IsSnapToTickEnabled="True"
                  ValueChanged="SaturationSlider_Changed"
                  VerticalAlignment="Center" />
          <TextBlock Grid.Column="2"
                     Name="SaturationVal"
                     Text="+0"
                     Foreground="#F7F5F3" FontSize="12" FontWeight="SemiBold"
                     VerticalAlignment="Center" HorizontalAlignment="Right" />
        </Grid>

        <!-- ── Geometry ─────────────────────────────────────────────────── -->
        <TextBlock Text="GEOMETRY"
                   FontSize="10" FontWeight="SemiBold"
                   Foreground="#807C79"
                   Margin="0,0,0,10" />

        <!-- Zoom -->
        <Grid ColumnDefinitions="86,*,56" Margin="0,0,0,10">
          <TextBlock Grid.Column="0" Text="Zoom"
                     VerticalAlignment="Center"
                     Foreground="#DEDAD5" FontSize="13" />
          <Slider Grid.Column="1"
                  Name="ZoomSlider"
                  Minimum="-100" Maximum="100"
                  TickFrequency="5" IsSnapToTickEnabled="True"
                  ValueChanged="ZoomSlider_Changed"
                  VerticalAlignment="Center" />
          <TextBlock Grid.Column="2"
                     Name="ZoomVal"
                     Text="100%"
                     Foreground="#F7F5F3" FontSize="12" FontWeight="SemiBold"
                     VerticalAlignment="Center" HorizontalAlignment="Right" />
        </Grid>
        <TextBlock Text="0 = original size  ·  positive = zoom in  ·  negative = zoom out"
                   FontSize="10" Foreground="#807C79" Margin="86,0,0,14" />

        <!-- Aspect ratio -->
        <Grid ColumnDefinitions="86,*" Margin="0,0,0,14">
          <TextBlock Grid.Column="0" Text="Aspect ratio"
                     VerticalAlignment="Center"
                     Foreground="#DEDAD5" FontSize="13" />
          <ComboBox Grid.Column="1"
                    Name="AspectCombo"
                    Background="#2D2D2D" Foreground="#F7F5F3"
                    BorderBrush="#4D4658"
                    MaxDropDownHeight="220"
                    Focusable="True"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="AspectCombo_SelectionChanged" />
        </Grid>

        <!-- Rotation -->
        <Grid ColumnDefinitions="86,*" Margin="0,0,0,6">
          <TextBlock Grid.Column="0" Text="Rotation"
                     VerticalAlignment="Center"
                     Foreground="#DEDAD5" FontSize="13" />
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
            <Button Name="Rot0Btn"   Content="0°"   MinWidth="58"
                    Click="RotButton_Click" Tag="0" />
            <Button Name="Rot90Btn"  Content="90°"  MinWidth="58"
                    Click="RotButton_Click" Tag="90" />
            <Button Name="Rot180Btn" Content="180°" MinWidth="58"
                    Click="RotButton_Click" Tag="180" />
            <Button Name="Rot270Btn" Content="270°" MinWidth="58"
                    Click="RotButton_Click" Tag="270" />
          </StackPanel>
        </Grid>

      </StackPanel>
    </ScrollViewer>

    <!-- ── Bottom action bar ─────────────────────────────────────────────── -->
    <Border Grid.Row="1" BorderBrush="#333333" BorderThickness="0,1,0,0" Margin="-20,0,-20,0">
      <Grid ColumnDefinitions="Auto,*,Auto,8,Auto" Margin="20,10,20,0">
        <Button Grid.Column="0"
                Name="ResetButton"
                Content="Reset all"
                Foreground="#FF9999"
                Click="ResetButton_Click" />
        <Border Grid.Column="1" />
        <Button Grid.Column="2"
                Name="CancelButton"
                Content="Cancel"
                Click="CancelButton_Click" />
        <Button Grid.Column="4"
                Name="OkButton"
                Content="Apply"
                Classes="accent"
                Click="OkButton_Click" />
      </Grid>
    </Border>

  </Grid>
</Window>
