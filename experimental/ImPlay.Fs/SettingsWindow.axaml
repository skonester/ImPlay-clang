<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="600"
        x:Class="ImPlay.Fs.SettingsWindow"
        Title="Settings"
        Width="500" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="White"
        RequestedThemeVariant="Dark">

    <Grid RowDefinitions="*,Auto">
        <TabControl Grid.Row="0" Margin="10">
            <!-- General Tab -->
            <TabItem Header="General">
                <ScrollViewer>
                    <StackPanel Spacing="15" Margin="10">
                        <TextBlock Text="Core" FontWeight="Bold"/>
                        <CheckBox Name="ChkSingleWindow" Content="Single Instance Mode"/>
                        <CheckBox Name="ChkUseMpvConfig" Content="Use mpv.conf"/>
                        <CheckBox Name="ChkWatchLater" Content="Save position on quit (watch-later)"/>
                        <CheckBox Name="ChkSaveWindow" Content="Remember window position/size"/>
                        
                        <Separator/>
                        <TextBlock Text="History" FontWeight="Bold"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Recent Files Limit" VerticalAlignment="Center"/>
                            <NumericUpDown Name="NumRecentLimit" Grid.Column="1" Minimum="0" Maximum="100" Value="15" Width="120"/>
                        </Grid>
                        
                        <Separator/>
                        <TextBlock Text="Debug" FontWeight="Bold"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Log Level" VerticalAlignment="Center"/>
                            <ComboBox Name="ComboLogLevel" Grid.Column="1" Width="120">
                                <ComboBoxItem Content="fatal"/>
                                <ComboBoxItem Content="error"/>
                                <ComboBoxItem Content="warn"/>
                                <ComboBoxItem Content="info"/>
                                <ComboBoxItem Content="status"/>
                                <ComboBoxItem Content="v"/>
                                <ComboBoxItem Content="debug"/>
                                <ComboBoxItem Content="trace"/>
                                <ComboBoxItem Content="no"/>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Interface Tab -->
            <TabItem Header="Interface">
                <ScrollViewer>
                    <StackPanel Spacing="15" Margin="10">
                        <TextBlock Text="Theme" FontWeight="Bold"/>
                        <ComboBox Name="ComboTheme" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Dark"/>
                            <ComboBoxItem Content="Light"/>
                            <ComboBoxItem Content="System"/>
                        </ComboBox>
                        
                        <TextBlock Text="Language" FontWeight="Bold"/>
                        <ComboBox Name="ComboLang" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="English"/>
                            <ComboBoxItem Content="Chinese (Simplified)"/>
                            <ComboBoxItem Content="Japanese"/>
                        </ComboBox>

                        <Separator/>
                        <TextBlock Text="Performance" FontWeight="Bold"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Target FPS" VerticalAlignment="Center"/>
                            <NumericUpDown Name="NumFps" Grid.Column="1" Minimum="15" Maximum="200" Value="60" Width="120"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Font Tab -->
            <TabItem Header="Font">
                <StackPanel Spacing="15" Margin="10">
                    <TextBlock Text="Custom UI Font" FontWeight="Bold"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Name="TxtFontPath" Watermark="System Default"/>
                        <Button Name="BtnBrowseFont" Grid.Column="1" Content="..." Margin="5,0,0,0"/>
                    </Grid>
                    
                    <TextBlock Text="Font Size" FontWeight="Bold"/>
                    <Slider Name="SliderFontSize" Minimum="8" Maximum="72" Value="14"/>
                    <TextBlock Text="{Binding ElementName=SliderFontSize, Path=Value, StringFormat={}{0:F0}px}" HorizontalAlignment="Right"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="15" Spacing="10">
            <Button Name="BtnOk" Content="OK" Width="80" IsDefault="True"/>
            <Button Name="BtnCancel" Content="Cancel" Width="80"/>
            <Button Name="BtnApply" Content="Apply" Width="80"/>
        </StackPanel>
    </Grid>
</Window>
