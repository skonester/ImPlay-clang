<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:domain="clr-namespace:ImPlay.Fs;assembly=ImPlay.Fs"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="ImPlay.Fs.DebugWindow"
        Title="Metrics &amp; Debug"
        Width="800" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="White"
        RequestedThemeVariant="Dark">

    <Grid RowDefinitions="*,Auto">
        <TabControl Grid.Row="0">
            <!-- Console & Logs -->
            <TabItem Header="Console">
                <Grid RowDefinitions="*,Auto,Auto">
                    <ListBox Name="ListLogs" Grid.Row="0" Background="#121212" FontFamily="Consolas,Monospace">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="domain:LogEntry">
                                <TextBlock Text="{Binding Message}" Foreground="{Binding Color}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    
                    <Separator Grid.Row="1"/>
                    
                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="5">
                        <TextBox Name="TxtConsoleInput" Watermark="Enter mpv command... (e.g. show-text 'Hello')" 
                                 FontFamily="Consolas,Monospace"/>
                        <Button Name="BtnSendCommand" Grid.Column="1" Content="Send" Margin="5,0,0,0"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Properties -->
            <TabItem Header="Properties">
                <Grid RowDefinitions="Auto,*">
                    <TextBox Name="TxtPropertyFilter" Watermark="Filter properties..." Margin="5"/>
                    <ListBox Name="ListProperties" Grid.Row="1" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="domain:PropertyEntry">
                                <Grid ColumnDefinitions="*,*">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="#4CAF50" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <!-- Commands -->
            <TabItem Header="Commands">
                <ListBox Name="ListCommands" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="domain:CommandEntry">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="{Binding Name}" Foreground="#2196F3" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Args}" Opacity="0.6"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="1" Name="TxtDebugStatus" Margin="10" FontSize="10" Opacity="0.5"/>
    </Grid>
</Window>
